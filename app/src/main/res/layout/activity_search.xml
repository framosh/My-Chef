<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDD0"
    android:fitsSystemWindows="true"> <!-- Margen superior automático -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- LOGO DE LA APP EN BÚSQUEDA -->
        <ImageView
            android:id="@+id/ivSearchLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo_chef"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TÍTULO DE BÚSQUEDA -->
        <TextView
            android:id="@+id/tvSearchTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Consultar Recetas"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            app:layout_constraintTop_toTopOf="@id/ivSearchLogo"
            app:layout_constraintBottom_toBottomOf="@id/ivSearchLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivSearchLogo" />

        <!-- Campo de Búsqueda (Ahora debajo del logo) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            app:hintTextColor="#5D4037"
            android:textColorHint="#5D4037"
            app:layout_constraintTop_toBottomOf="@id/ivSearchLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSearch">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del platillo..."
                android:textColor="#3E2723"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUSCAR"
            android:backgroundTint="#3E2723"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="@id/tilSearch"
            app:layout_constraintBottom_toBottomOf="@id/tilSearch"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Etiqueta para el Spinner -->
        <TextView
            android:id="@+id/tvFilterLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtrar por tipo:"
            android:layout_marginTop="12dp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            app:layout_constraintTop_toBottomOf="@id/tilSearch"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spinnerSearchCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#F5F5DC"
            android:backgroundTint="#3E2723"
            app:layout_constraintTop_toBottomOf="@id/tvFilterLabel" />

        <!-- Contenedor de Resultados con contraste -->
        <!-- Matriz simple de una sola columna para nombres de platillos -->
        <ListView
            android:id="@+id/lvRecipes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="80dp"

            android:background="@android:color/transparent"
            android:divider="#8D6E63"
            android:dividerHeight="1dp"

            android:listSelector="#D7CCC8"
            app:layout_constraintTop_toBottomOf="@id/spinnerSearchCategory"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTÓNES FLOTANTES PARA REGRESAR A LA PAGINA ANTERIOR O PARA BORRAR UN REGISTRO -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="48dp"
        app:backgroundTint="#5D4037"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:tint="@android:color/white"
        android:contentDescription="Volver al registro" />

    <!-- BOTÓN FLOTANTE PARA ELIMINAR (Derecha) - NUEVO -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="48dp"
        android:visibility="gone"
        app:backgroundTint="#B71C1C"
        app:srcCompat="@android:drawable/ic_menu_delete"
        app:tint="@android:color/white"
        android:contentDescription="Eliminar receta seleccionada" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
